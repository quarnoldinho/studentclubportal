<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Member Registration - Student Club Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="index.html">Student Club Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="index.html">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="members.html">Member Registration</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container my-5">
    <div class="row g-4">
      
      <div class="col-lg-5">
        <div class="card shadow-sm">
          <div class="card-header bg-primary text-white">
            <h1 class="h4 mb-0">Register / Update Member</h1>
          </div>
          <div class="card-body">
            <div id="messageBox"></div>

            <form id="memberForm" novalidate>
              <input type="hidden" id="editIndex" value="-1">

              <div class="mb-3">
                <label for="memberName" class="form-label">Member Name *</label>
                <input type="text" class="form-control" id="memberName">
                <div class="invalid-feedback">Please enter the member name.</div>
              </div>

              <div class="mb-3">
                <label for="email" class="form-label">Email Address *</label>
                <input type="email" class="form-control" id="email">
                <div class="invalid-feedback">Please enter a valid email address.</div>
              </div>

              <div class="mb-3">
                <label for="yearLevel" class="form-label">Year / Grade Level *</label>
                <input type="text" class="form-control" id="yearLevel" placeholder="Freshman, Sophomore, Senior...">
                <div class="invalid-feedback">Please enter year or grade level.</div>
              </div>

              <div class="mb-3">
                <label for="organization" class="form-label">Institution / Organization *</label>
                <input type="text" class="form-control" id="organization">
                <div class="invalid-feedback">Please enter institution or organization.</div>
              </div>

              <div class="mb-3">
                <label for="phone" class="form-label">Contact Number</label>
                <input type="text" class="form-control" id="phone" placeholder="Optional">
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Member</button>
                <button type="button" id="clearBtn" class="btn btn-secondary">Clear Form</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-dark text-white">
            <h2 class="h5 mb-0">Member Directory</h2>
          </div>
          <div class="card-body table-responsive">
            <table class="table table-striped table-hover align-middle" id="memberTable">
              <thead class="table-primary">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Year</th>
                  <th>Organization</th>
                  <th>Phone</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="memberTableBody">
              </tbody>
            </table>
          </div>
        </div>

        <div class="card shadow-sm">
          <div class="card-header bg-success text-white">
            <h2 class="h5 mb-0">JSON Data Preview</h2>
          </div>
          <div class="card-body">
            <pre id="jsonOutput" class="json-box">[]</pre>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="bg-dark text-white text-center py-3">
    <p class="mb-0">&copy; 2026 Student Club Portal Project</p>
  </footer>

  <script src="script.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>